# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Postgres connection string from Neon (https://neon.tech) or Supabase (https://supabase.com).
# Free tier is plenty. Use the pooled connection string for Vercel deployments.
DATABASE_URL=

# Claude API key from https://platform.claude.com
ANTHROPIC_API_KEY=

# Model IDs — see CLAUDE.md "AI cost discipline". Extraction stays on Haiku;
# insights start on Sonnet 5 (swap to claude-opus-4-8 later if desired).
EXTRACTION_MODEL=claude-haiku-4-5
INSIGHTS_MODEL=claude-sonnet-5
